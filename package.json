{
  "name": "linkedin-profile-auditor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Extrae tu propio perfil de LinkedIn con Playwright y audítalo (headline, about, experiencia, skills, certificaciones, recomendaciones). Incluye generador de banner de perfil.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/imkhub1/linkedin-profile-auditor.git"
  },
  "keywords": ["linkedin", "playwright", "profile-audit", "career", "automation"],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node src/cli.mjs",
    "doctor": "node src/doctor.mjs",
    "login": "node src/scraping/login.mjs",
    "scrape": "node src/scraping/scrape-profile.mjs",
    "logout": "node src/cleanup.mjs logout",
    "clean": "node src/cleanup.mjs clean",
    "banner:logo": "node src/banner/process-logo.mjs",
    "banner:render": "node src/banner/render-banner.mjs",
    "typecheck": "tsc --project jsconfig.json",
    "test": "node --test"
  },
  "dependencies": {
    "@fontsource/inter": "^5.3.0",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
